{
  "name": "@codedesignplus/generator-cli",
  "version": "0.0.1",
  "description": "yeoman generator codedesignplus",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "unlink": "npm unlink generator-codedesignplus -g",
    "link": "npm link",
    "local": "npm run unlink && npm run link && yo --generators",
    "submodule": "git submodule update --remote",
    "submodule:net:library": "git clone --recurse-submodules https://github.com/codedesignplus/CodeDesignPlus.Net.Library submodules/CodeDesignPlus.Net.Library"
  },
  "files": [
    "generators"
  ],
  "keywords": [
    "yeoman",
    "generator",
    "codedesignplus",
    "library",
    "microservices"
  ],
  "author": "CodeDesignPlus",
  "license": "MIT",
  "dependencies": {
    "glob": "^10.4.1",
    "gulp-replace": "^1.1.4",
    "yeoman-generator": "^7.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.24.7",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "yeoman-assert": "^3.1.1",
    "yeoman-test": "^8.3.0"
  }
}
